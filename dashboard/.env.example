# Cognito Dashboard — Environment Variables for Vercel Deployment
# Copy these to Vercel project settings → Environment Variables

# Circle Developer Credentials
CIRCLE_API_KEY=TEST_API_KEY:your_key_here
CIRCLE_ENTITY_SECRET=your_64_char_secret_here

# Wallet IDs & Addresses
OWNER_WALLET_ID=
OWNER_WALLET_ADDRESS=
VALIDATOR_WALLET_ID=
VALIDATOR_WALLET_ADDRESS=

# Agent Identity
AGENT_ID=23745
METADATA_URI=ipfs://QmStDueZCXru2DhzR743Q451YY5Uor68UPGv4Eyr4aumdm

# Inference
GROQ_API_KEY=your_groq_key_here

# IPFS (Pinata)
PINATA_API_KEY=
PINATA_API_SECRET_KEY=

# Streaming
ENABLE_STREAMING=true
STREAMING_RATE_USDC=0.0001

# DO NOT set NEXT_PUBLIC_IS_LOCAL in Vercel
# This ensures production read-only mode
